<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>De puzzel van Raisa — Journey Business Studies</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --geel: #FFCB3E;
  --koraal: #FB836F;
  --roze: #C1549C;
  --paars: #7E549F;
  --wit: #F7F5F0;
  --zwart: #1C1A18;
  --grijs: #6B6660;
  --grijs-licht: #E4E1DA;
  --geel-donker: #7a5800;
  --koraal-donker: #7a2c18;
  --roze-donker: #5a1a47;
  --paars-donker: #3a1f5a;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--wit);
  color: var(--zwart);
  overflow-x: hidden;
}

/* ─── NAVIGATIE ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 3rem;
  background: rgba(247,245,240,0.92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--grijs-licht);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: var(--zwart);
}
.nav-items {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.nav-items a {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--grijs);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-items a:hover { color: var(--zwart); }

/* ─── PROGRESSIEBALK ─── */
.progressbar {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  background: var(--geel);
  z-index: 300;
  width: 0%;
  transition: width 0.1s linear;
}

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 55% 45%;
  padding-top: 64px;
}
.hero-links {
  background: var(--zwart);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 4rem 5rem 5rem;
  position: relative;
  overflow: hidden;
}
.hero-links::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 400px; height: 400px;
  border-radius: 50%;
  border: 60px solid rgba(255,203,62,0.08);
}
.hero-links::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 280px; height: 280px;
  border-radius: 50%;
  border: 40px solid rgba(255,203,62,0.05);
}
.hero-label {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--geel);
  margin-bottom: 1.5rem;
}
.hero-titel {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 5vw, 4.2rem);
  font-weight: 900;
  line-height: 1.05;
  color: #fff;
  margin-bottom: 0.5rem;
}
.hero-titel em {
  font-style: italic;
  color: var(--geel);
}
.hero-subtitel {
  font-size: 1.05rem;
  font-weight: 300;
  color: rgba(255,255,255,0.55);
  margin-bottom: 2.5rem;
  line-height: 1.5;
}
.hero-meta {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.hero-meta span {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.04em;
}
.hero-meta strong {
  color: rgba(255,255,255,0.75);
  font-weight: 400;
}

.hero-rechts {
  background: var(--geel);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 4rem 3.5rem;
  position: relative;
  overflow: hidden;
}
.hero-rechts::before {
  content: '';
  position: absolute;
  top: 3rem; right: 3rem;
  width: 180px; height: 180px;
  border-radius: 50%;
  background: rgba(0,0,0,0.06);
}
.puzzel-preview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 2.5rem;
  position: relative;
  z-index: 1;
}
.puzzel-stuk {
  background: rgba(0,0,0,0.1);
  border-radius: 6px;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.5);
  text-align: center;
  padding: 0.5rem;
  line-height: 1.3;
}
.puzzel-stuk.gevuld {
  background: rgba(0,0,0,0.18);
  color: rgba(0,0,0,0.7);
}
.hero-quote {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem;
  font-style: italic;
  color: var(--zwart);
  line-height: 1.5;
  position: relative;
  z-index: 1;
}
.hero-quote::before {
  content: '"';
  font-size: 4rem;
  line-height: 0.8;
  display: block;
  opacity: 0.2;
  font-family: 'Playfair Display', serif;
  margin-bottom: 0.5rem;
}

/* ─── FADE-UP ANIMATIE ─── */
.fade-up {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.fade-up.zichtbaar {
  opacity: 1;
  transform: translateY(0);
}

/* ─── SECTIE STIJLEN ─── */
section { padding: 6rem 0; }

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 4rem;
}
.container-smal {
  max-width: 780px;
  margin: 0 auto;
  padding: 0 4rem;
}

/* Fase-kleurband */
.fase-band {
  height: 6px;
  width: 100%;
}

/* Sectie-header */
.sectie-header {
  display: flex;
  align-items: flex-start;
  gap: 2rem;
  margin-bottom: 3.5rem;
}
.sectie-nummer {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: var(--grijs);
  letter-spacing: 0.08em;
  padding-top: 0.4rem;
  white-space: nowrap;
}
.sectie-titels h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 0.6rem;
}
.sectie-titels p {
  font-size: 1rem;
  color: var(--grijs);
  font-weight: 300;
  line-height: 1.6;
  max-width: 600px;
}

/* Fase-label pill */
.fase-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0.9rem;
  border-radius: 20px;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.fase-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
}

/* Lopende tekst */
.body-tekst {
  font-size: 1.05rem;
  line-height: 1.85;
  font-weight: 300;
  color: var(--zwart);
  margin-bottom: 1.5rem;
}
.body-tekst strong {
  font-weight: 500;
}

/* Pullquote */
.pullquote {
  border-left: 3px solid var(--geel);
  padding: 0.8rem 0 0.8rem 2rem;
  margin: 2.5rem 0;
}
.pullquote p {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-style: italic;
  line-height: 1.5;
  color: var(--zwart);
}

/* Theoriekader */
.theorie-kader {
  background: var(--zwart);
  color: #fff;
  border-radius: 12px;
  padding: 2rem 2.5rem;
  margin: 2.5rem 0;
}
.theorie-kader .theorie-label {
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--geel);
  margin-bottom: 0.75rem;
}
.theorie-kader p {
  font-size: 0.95rem;
  line-height: 1.75;
  color: rgba(255,255,255,0.8);
  font-weight: 300;
}
.theorie-kader cite {
  display: block;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.4);
  margin-top: 0.75rem;
  font-style: normal;
  letter-spacing: 0.04em;
}

/* Competentie-kaart */
.comp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin: 2.5rem 0;
}
.comp-kaart {
  background: #fff;
  border-radius: 10px;
  padding: 1.5rem;
  border: 1px solid var(--grijs-licht);
  border-top-width: 4px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.comp-kaart:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.07);
}
.comp-kop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 0.75rem;
  gap: 0.5rem;
}
.comp-naam {
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--zwart);
  line-height: 1.3;
}
.comp-weging {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  color: var(--grijs);
  white-space: nowrap;
}
.comp-tekst {
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--grijs);
  font-weight: 300;
  margin-bottom: 1rem;
}
.comp-bewijs {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  padding: 0.3rem 0.75rem;
  border-radius: 20px;
  display: inline-block;
}

/* Tijdlijn */
.tijdlijn {
  position: relative;
  padding-left: 2.5rem;
  margin: 2.5rem 0;
}
.tijdlijn::before {
  content: '';
  position: absolute;
  left: 8px; top: 6px; bottom: 6px;
  width: 2px;
  background: var(--grijs-licht);
}
.tijdlijn-item {
  position: relative;
  margin-bottom: 2rem;
}
.tijdlijn-item::before {
  content: '';
  position: absolute;
  left: -2.5rem;
  top: 6px;
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--grijs-licht);
  border: 2px solid var(--wit);
}
.tijdlijn-item.actief::before {
  background: var(--geel);
  border-color: var(--geel);
}
.tijdlijn-jaar {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--grijs);
  margin-bottom: 0.25rem;
  letter-spacing: 0.06em;
}
.tijdlijn-titel {
  font-size: 0.95rem;
  font-weight: 500;
  margin-bottom: 0.3rem;
}
.tijdlijn-tekst {
  font-size: 0.88rem;
  color: var(--grijs);
  line-height: 1.6;
  font-weight: 300;
}

/* Grote quote band */
.quote-band {
  background: var(--zwart);
  padding: 5rem 0;
  overflow: hidden;
  position: relative;
}
.quote-band::before {
  content: '❝';
  position: absolute;
  font-size: 20rem;
  color: rgba(255,255,255,0.03);
  top: -3rem;
  left: 2rem;
  font-family: serif;
  line-height: 1;
}
.quote-band-tekst {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-style: italic;
  color: #fff;
  line-height: 1.45;
  text-align: center;
  max-width: 820px;
  margin: 0 auto;
  padding: 0 4rem;
  position: relative;
  z-index: 1;
}
.quote-band-bron {
  text-align: center;
  margin-top: 1.25rem;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 500;
}

/* Scheidingsband met kleur */
.kleur-band {
  padding: 3.5rem 0;
  position: relative;
}

/* Twee-kolom layout */
.twee-kolom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

/* Highlight box */
.highlight-box {
  border-radius: 10px;
  padding: 1.75rem 2rem;
  margin: 2rem 0;
}

/* Afsluiting */
.afsluiting {
  background: var(--zwart);
  padding: 8rem 0 6rem;
  text-align: center;
}
.afsluiting-puzzel {
  display: grid;
  grid-template-columns: repeat(4, 60px);
  gap: 8px;
  justify-content: center;
  margin: 0 auto 3rem;
}
.afsluiting-puzzel-stuk {
  width: 60px; height: 60px;
  border-radius: 8px;
}
.afsluiting h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.afsluiting h2 em {
  font-style: italic;
  color: var(--geel);
}
.afsluiting-tekst {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.55);
  font-weight: 300;
  line-height: 1.75;
  max-width: 620px;
  margin: 0 auto 3rem;
}
.afsluiting-vraag {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 2rem 2.5rem;
  max-width: 580px;
  margin: 0 auto 3rem;
}
.afsluiting-vraag p {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-style: italic;
